# SLS Management UI Environment Variables

# Base URL for the SRT API server
APP_URL=http://localhost:8080

# Ports
SRT_PLAYER_PORT=4000
SRT_SENDER_PORT=4001
SLS_STATS_PORT=8080
SRTLA_PORT=5000

# RIST management API URL
RIST_API_URL=http://localhost:3001
RIST_API_PORT=3001

# API key for RIST API (leave empty to disable auth in dev)
RIST_API_KEY=change-me-in-production

# CORS allowed origin for RIST API (use specific domain in prod, * for dev)
CORS_ORIGIN=*

# UI port (prod only)
UI_PORT=80
