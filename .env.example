# ── UIRist + Belabox Receiver Stack ──────────────────────────────────────────

# Server public IP or domain (used to build API URLs baked into the React build)
# Example: http://192.168.1.10   or   https://stream.example.com
APP_URL=http://YOUR_SERVER_IP:8181

# ── Belabox / SRT (bbox-receiver) ────────────────────────────────────────────
SRT_PLAYER_PORT=8282       # SRT output port (OBS connects here)
SRT_SENDER_PORT=5000       # SRTLA input port (Belabox connects here)
SLS_STATS_PORT=8181        # SLS management API port
SRTLA_PORT=5000

# ── RIST (UIRist API) ─────────────────────────────────────────────────────────
RIST_API_URL=http://YOUR_SERVER_IP:3001
# Hostname shown in RIST input URLs (e.g. your-server.example.com). Defaults to RIST_API_URL hostname if empty.
RIST_SERVER_HOST=
RIST_API_PORT=3001

# API key for RIST API (leave empty to disable auth — NOT recommended for prod)
RIST_API_KEY=change-me-in-production

# CORS allowed origin (use specific domain in prod, * for dev/LAN)
CORS_ORIGIN=*

# ── UI ────────────────────────────────────────────────────────────────────────
UI_PORT=80
